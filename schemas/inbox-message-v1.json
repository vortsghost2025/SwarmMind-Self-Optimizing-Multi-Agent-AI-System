{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SwarmMind Inbox Message v1.1",
  "description": "Schema for lane-relay inbox messages per the v1.1 contract. Key changes from v1.0: from/to replace from_lane/to_lane, heartbeat.status uses enum, added watcher/delivery_verification blocks, payload.compression, execution.parent_id/actor.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "task_id",
    "idempotency_key",
    "from",
    "to",
    "type",
    "priority",
    "subject",
    "timestamp",
    "signature",
    "key_id",
    "content_hash"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0", "1.1"],
      "description": "Message schema version. v1.1 is the current canonical version."
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T",
      "description": "Unique message identifier with ISO timestamp prefix"
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "description": "Links to originating task"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1,
      "description": "Dedup key; must end with or contain the sender lane name"
    },
    "from": {
      "type": "string",
      "enum": ["archivist", "library", "swarmmind", "kernel"],
      "description": "Sender lane (replaces v1.0 from_lane)"
    },
    "to": {
      "type": "string",
      "enum": ["archivist", "library", "swarmmind", "kernel"],
      "description": "Target lane (replaces v1.0 to_lane)"
    },
    "type": {
      "type": "string",
      "enum": ["task", "status", "ack", "proposal", "review", "alert"],
      "description": "Message type"
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"],
      "description": "Message priority level"
    },
    "subject": {
      "type": "string",
      "minLength": 1,
      "description": "Summary line"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "task_kind": {
      "type": "string",
      "description": "Optional task kind classifier"
    },
    "body": {
      "type": "string",
      "description": "Optional message body"
    },
    "requires_action": {
      "type": "boolean",
      "default": false,
      "description": "Whether the recipient must take action"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "description": "v1.1 payload extension",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["inline", "indirect"],
          "description": "Payload delivery mode"
        },
        "compression": {
          "type": "string",
          "enum": ["none", "gzip", "zstd"],
          "default": "none",
          "description": "Compression algorithm for payload body"
        },
        "path": {
          "type": ["string", "null"],
          "description": "Path to external payload file (for indirect mode)"
        },
        "chunk": {
          "type": "object",
          "properties": {
            "index": { "type": "integer", "minimum": 0 },
            "count": { "type": "integer", "minimum": 1 },
            "group_id": { "type": ["string", "null"] }
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "description": "v1.1 execution provenance extension",
      "properties": {
        "mode": {
          "type": "string",
          "description": "Execution mode (e.g., session_task, automated)"
        },
        "engine": {
          "type": "string",
          "description": "Execution engine (e.g., kilo)"
        },
        "actor": {
          "type": "string",
          "enum": ["lane", "subagent", "watcher"],
          "description": "Execution actor type"
        },
        "session_id": {
          "type": ["string", "null"],
          "description": "Session identifier"
        },
        "parent_id": {
          "type": ["string", "null"],
          "description": "Parent execution context ID"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "description": "Evidence tracking for verification",
      "properties": {
        "required": {
          "type": "boolean",
          "description": "Whether evidence is required for this message"
        },
        "evidence_path": {
          "type": "string"
        },
        "verified": {
          "type": "boolean"
        },
        "verified_by": {
          "type": "string"
        },
        "verified_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "lease": {
      "type": "object",
      "additionalProperties": false,
      "description": "Message lease for claiming/acquisition",
      "properties": {
        "owner": {
          "type": "string"
        },
        "acquired_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "renew_count": {
          "type": "integer",
          "minimum": 0
        },
        "max_renewals": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Retry tracking for failed message processing",
      "properties": {
        "attempt": {
          "type": "integer",
          "minimum": 0
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 0
        },
        "last_error": {
          "type": ["string", "null"]
        },
        "last_attempt_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "heartbeat": {
      "type": "object",
      "additionalProperties": false,
      "description": "Heartbeat tracking for lane liveness",
      "properties": {
        "interval_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "last_heartbeat_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "done", "failed", "escalated", "timed_out"],
          "description": "Heartbeat status — v1.1 restricts to these enum values (replaces v1.0 'active')"
        }
      }
    },
    "watcher": {
      "type": "object",
      "additionalProperties": false,
      "description": "v1.1 watcher policy block",
      "properties": {
        "enabled": { "type": "boolean" },
        "poll_seconds": { "type": "integer", "minimum": 1 },
        "p0_fast_path": { "type": "boolean" },
        "max_concurrent": { "type": "integer", "minimum": 1 },
        "heartbeat_required": { "type": "boolean" },
        "stale_after_seconds": { "type": "integer", "minimum": 1 },
        "backoff": {
          "type": "object",
          "properties": {
            "initial_seconds": { "type": "integer" },
            "max_seconds": { "type": "integer" },
            "multiplier": { "type": "number" }
          }
        }
      }
    },
    "delivery_verification": {
      "type": "object",
      "additionalProperties": false,
      "description": "v1.1 delivery verification block",
      "properties": {
        "verified": { "type": "boolean" },
        "verified_at": { "type": ["string", "null"], "format": "date-time" },
        "retries": { "type": "integer", "minimum": 0 }
      }
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 content hash for verification depth"
    },
    "signature": {
      "type": "string",
      "description": "JWS compact serialization signature"
    },
    "signature_alg": {
      "type": "string",
      "enum": ["RS256"],
      "description": "Signature algorithm"
    },
    "key_id": {
      "type": "string",
      "description": "Identifier linking to trust store key"
    }
  }
}

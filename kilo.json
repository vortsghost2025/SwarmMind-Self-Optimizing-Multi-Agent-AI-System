{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "ollama/qwen2.5-coder:7b",
  "agent": {
    "orchestrator": {
      "model": "ollama/qwen2.5-coder:7b"
    },
    "plan": {
      "model": "ollama/qwen2.5-coder:7b"
    },
    "code": {
      "model": "ollama/deepseek-coder:6.7b"
    },
    "build": {
      "model": "ollama/deepseek-coder:6.7b"
    },
    "debug": {
      "model": "ollama/qwen2.5-coder:7b"
    },
    "ask": {
      "model": "ollama/qwen2.5-coder:7b"
    },
    "general": {
      "model": "ollama/qwen2.5-coder:7b"
    }
  },
  "provider": {
    "ollama": {
      "models": {
        "deepseek-coder:6.7b": {
          "name": "DeepSeek Coder 6.7B",
          "tool_call": true,
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "options": {
            "num_ctx": 32768,
            "temperature": 0.1
          }
        },
        "qwen2.5-coder:7b": {
          "name": "Qwen2.5 Coder 7B",
          "tool_call": true,
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "options": {
            "num_ctx": 32768,
            "temperature": 0.2
          }
        }
      }
    },
    "z-ai": {
      "base_url": "https://integrate.api.nvidia.com/v1",
      "models": {
        "glm5": {
          "name": "GLM-5",
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    }
  },
  "permission": {
    "external_directory": {
      "S:\\Archivist-Agent": "allow",
      "S:\\Archivist-Agent\\swarmmind-governance-extension": "allow",
      "*": "allow"
    },
    "bash": {
      "*": "allow"
    },
    "read": {
      "*": "allow"
    },
    "write": {
      "*": "allow"
    },
    "edit": {
      "*": "allow"
    },
    "web": {
      "*": "allow"
    }
  }
}

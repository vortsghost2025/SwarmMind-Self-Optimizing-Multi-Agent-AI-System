[Unit]
Description=SwarmMind Lane Worker — autonomous inbox processor
After=network.target

[Service]
Type=simple
ExecStart=/home/we4free/.nvm/versions/node/v20.20.2/bin/node /home/we4free/agent/repos/SwarmMind/scripts/lane-worker.js --lane swarmmind --apply --watch --poll-seconds 20
WorkingDirectory=/home/we4free/agent/repos/SwarmMind
Restart=on-failure
RestartSec=10
Environment=NODE_ENV=production
Environment=LANE_NAME=swarmmind
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus

[Install]
WantedBy=default.target
